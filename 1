  <div class="stage-veil"></div>

  <div class="manifest-tag hidden md:block">
    <span class="code">DOC // VV-0001</span>
    <div class="sub">ORIGIN: TAMPA, FL<br/>STATUS: ACTIVE CONTRACTOR</div>
  </div>

  <div class="relative z-10 px-6 max-w-5xl reveal is-visible">
    <p class="eyebrow mb-6">Federal Contracting &amp; Technology Systems</p>
    <h1 class="font-display font-800 text-[13vw] md:text-[7.5vw] leading-[0.95] tracking-tight text-[#E8E6DE]">
      VENTORO<br/><span class="text-[#B8924A]">VENTURES</span>
    </h1>
    <p class="mt-8 text-lg md:text-2xl font-light text-[#E8E6DE]/90 tracking-wide">
      Powering Progress. Delivering Innovation.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#about" class="btn-gold font-mono text-xs uppercase tracking-widest px-7 py-4">
        Explore Capabilities
      </a>
      <a href="#contact" class="btn-outline font-mono text-xs uppercase tracking-widest px-7 py-4">
        Contracting Officers →
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 font-mono text-[10px] tracking-[0.3em] text-[#7C8893] uppercase">
    Scroll
  </div>
</section>

<!-- ============ 2. ABOUT ============ -->
<section class="relative bg-[#0A0D10] py-28 md:py-40 px-6 md:px-16" id="about">
  <div class="manifest-tag hidden md:block" style="position:absolute; top:2.5rem; right:2.5rem;">
    <span class="code">DOC // VV-0002</span>
    <div class="sub">CLASS: CORPORATE PROFILE</div>
  </div>

  <div class="max-w-6xl mx-auto grid md:grid-cols-[auto_1fr] gap-10 md:gap-16">
    <div class="rule-gold hidden md:block"></div>
    <div>
      <p class="eyebrow reveal">About the Firm</p>
      <h2 class="font-display font-700 text-4xl md:text-6xl mt-5 leading-[1.05] text-[#E8E6DE] reveal reveal-delay-1">
        A newly founded government contracting firm built on the intersection of global logistics and artificial intelligence.
      </h2>

      <div class="grid md:grid-cols-3 gap-10 mt-16">
        <div class="reveal reveal-delay-2">
          <p class="stat-num text-4xl">FL</p>
          <p class="font-mono text-xs uppercase tracking-widest text-[#7C8893] mt-2">Florida-Based<br/>Headquarters</p>
        </div>
        <div class="reveal reveal-delay-2">
          <p class="stat-num text-4xl">02</p>
          <p class="font-mono text-xs uppercase tracking-widest text-[#7C8893] mt-2">Operating<br/>Divisions</p>
        </div>
        <div class="reveal reveal-delay-3">
          <p class="stat-num text-4xl">100%</p>
          <p class="font-mono text-xs uppercase tracking-widest text-[#7C8893] mt-2">Compliance-First<br/>Architecture</p>
        </div>
      </div>

      <p class="mt-14 text-base md:text-lg text-[#7C8893] leading-relaxed max-w-2xl reveal reveal-delay-3">
        Ventoro Ventures operates a dual-track model purpose-built for federal procurement: a commodity brokering and logistics arm that moves hardware and infrastructure directly into agency hands, paired with a custom AI software division engineering compliant, mission-ready systems. One firm. Two disciplines. A single standard of execution.
      </p>
    </div>
  </div>
</section>

<!-- ============ 3. COMMODITY LOGISTICS ============ -->
<section class="stage items-end" id="logistics">
  <div class="stage-bg" style="background-image:url('https://images.unsplash.com/photo-0A7YwYhZhWw?auto=format&fit=crop&w=2400&q=80'); filter:grayscale(0.15) brightness(0.85);"></div>
  <div class="stage-veil"></div>

  <div class="manifest-tag hidden md:block">
    <span class="code">DOC // VV-0003</span>
    <div class="sub">DIVISION: LOGISTICS<br/>MANIFEST: COMMODITY / INFRA</div>
  </div>

  <div class="relative z-10 px-6 md:px-16 pb-20 md:pb-28 w-full">
    <div class="max-w-6xl mx-auto grid md:grid-cols-[auto_1fr] gap-10 md:gap-16">
      <div class="rule-gold hidden md:block"></div>
      <div>
        <p class="eyebrow reveal">Division 01 — Commodity &amp; Logistics</p>
        <h2 class="font-display font-700 text-4xl md:text-6xl mt-5 text-[#E8E6DE] reveal reveal-delay-1">
          Supply lines built<br/>for federal scale.
        </h2>
        <p class="mt-6 max-w-xl text-[#E8E6DE]/80 leading-relaxed reveal reveal-delay-2">
          Ventoro sources and routes hardware, infrastructure components, and commercial goods directly to government agencies, eliminating warehousing friction through engineered drop-ship pipelines.
        </p>

        <div class="grid sm:grid-cols-3 gap-8 mt-14 max-w-3xl">
          <div class="card-line pt-6 reveal reveal-delay-1">
            <p class="font-display font-700 text-lg text-[#B8924A]">Wholesale Sourcing</p>
            <p class="text-sm text-[#7C8893] mt-2 leading-relaxed">Direct manufacturer relationships cut cost and lead time at every tier of the supply chain.</p>
          </div>
          <div class="card-line pt-6 reveal reveal-delay-2">
            <p class="font-display font-700 text-lg text-[#B8924A]">Federal Drop-Shipping</p>
            <p class="text-sm text-[#7C8893] mt-2 leading-relaxed">Point-to-agency delivery infrastructure built around procurement timelines, not warehouse cycles.</p>
          </div>
          <div class="card-line pt-6 reveal reveal-delay-3">
            <p class="font-display font-700 text-lg text-[#B8924A]">Supply Chain Efficiency</p>
            <p class="text-sm text-[#7C8893] mt-2 leading-relaxed">Routing and vendor logic engineered to compress cost-per-unit without compromising compliance.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ 4. AI SOLUTIONS ============ -->
<section class="stage items-end" id="ai">
  <div class="stage-bg" style="background-image:url('https://images.unsplash.com/photo-M5tzZtFCOfs?auto=format&fit=crop&w=2400&q=80');"></div>
  <div class="stage-veil-flat"></div>

  <div class="manifest-tag hidden md:block">
    <span class="code">DOC // VV-0004</span>
    <div class="sub">DIVISION: AI SYSTEMS<br/>MANIFEST: SOFTWARE / DEFENSE</div>
  </div>

  <div class="relative z-10 px-6 md:px-16 pb-20 md:pb-28 w-full">
    <div class="max-w-6xl mx-auto grid md:grid-cols-[auto_1fr] gap-10 md:gap-16">
      <div class="rule-gold hidden md:block"></div>
      <div>
        <p class="eyebrow reveal">Division 02 — AI Solutions</p>
        <h2 class="font-display font-700 text-4xl md:text-6xl mt-5 text-[#E8E6DE] reveal reveal-delay-1">
          Custom software,<br/>built for compliance.
        </h2>
        <p class="mt-6 max-w-xl text-[#E8E6DE]/80 leading-relaxed reveal reveal-delay-2">
          Our engineering division designs and ships high-technology software solutions for agency partners — systems generated, tested, and hardened against the standards mission-critical work demands.
        </p>

        <div class="grid sm:grid-cols-3 gap-8 mt-14 max-w-3xl">
          <div class="card-line pt-6 reveal reveal-delay-1">
            <p class="font-display font-700 text-lg text-[#B8924A]">Custom Generation</p>
            <p class="text-sm text-[#7C8893] mt-2 leading-relaxed">Software architected around the agency's mission, not retrofitted from a commercial template.</p>
          </div>
          <div class="card-line pt-6 reveal reveal-delay-2">
            <p class="font-display font-700 text-lg text-[#B8924A]">Defense-Ready Innovation</p>
            <p class="text-sm text-[#7C8893] mt-2 leading-relaxed">Built to operate within the security and reliability tolerances of defense and federal environments.</p>
          </div>
          <div class="card-line pt-6 reveal reveal-delay-3">
            <p class="font-display font-700 text-lg text-[#B8924A]">Compliant by Design</p>
            <p class="text-sm text-[#7C8893] mt-2 leading-relaxed">Federal compliance frameworks built into the architecture from the first line of code.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ TRUST / GOV STRIP ============ -->
<section class="stage items-center justify-center text-center" style="min-height:75vh;">
  <div class="stage-bg" style="background-image:url('https://images.unsplash.com/photo-luOHcHUkirA?auto=format&fit=crop&w=2400&q=80');"></div>
  <div class="stage-veil"></div>

  <div class="manifest-tag hidden md:block">
