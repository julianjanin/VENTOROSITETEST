    <div class="sub">STATUS: REGISTERED ENTITY<br/>STATE OF FLORIDA</div>
  </div>

  <div class="relative z-10 px-6 max-w-3xl reveal">
    <p class="eyebrow mb-6">Built on Trust</p>
    <h2 class="font-display font-700 text-3xl md:text-5xl leading-tight text-[#E8E6DE]">
      Engineered for the standards federal procurement demands.
    </h2>
    <p class="mt-6 text-[#7C8893] leading-relaxed max-w-xl mx-auto">
      Every shipment, every system, every line of code is built to withstand the scrutiny of the agencies we serve.
    </p>
  </div>
</section>

<!-- ============ 5. CONTACT / FOOTER ============ -->
<section class="relative bg-[#0A0D10] pt-28 md:pt-36 pb-12 px-6 md:px-16" id="contact">
  <div class="manifest-tag hidden md:block" style="position:absolute; top:2.5rem; right:2.5rem;">
    <span class="code">DOC // VV-0006</span>
    <div class="sub">CLASS: CONTACT / OUTREACH</div>
  </div>

  <div class="max-w-6xl mx-auto grid md:grid-cols-[auto_1fr] gap-10 md:gap-16">
    <div class="rule-gold hidden md:block"></div>
    <div>
      <p class="eyebrow reveal">Contracting Inquiries</p>
      <h2 class="font-display font-700 text-4xl md:text-6xl mt-5 text-[#E8E6DE] reveal reveal-delay-1 max-w-2xl">
        Let's put a manifest together.
      </h2>
      <p class="mt-6 max-w-xl text-[#7C8893] leading-relaxed reveal reveal-delay-2">
        Contracting officers, prime partners, and procurement teams — reach out directly. We respond within one business day.
      </p>

      <form class="mt-14 max-w-xl space-y-8 reveal reveal-delay-2" onsubmit="event.preventDefault(); this.querySelector('.confirm').classList.remove('hidden');">
        <div class="grid sm:grid-cols-2 gap-8">
          <div>
            <label class="font-mono text-xs uppercase tracking-widest text-[#7C8893]">Name</label>
            <input type="text" required placeholder="Full name" class="field-input w-full mt-2 py-2 text-[#E8E6DE]" />
          </div>
          <div>
            <label class="font-mono text-xs uppercase tracking-widest text-[#7C8893]">Agency / Organization</label>
            <input type="text" placeholder="Agency name" class="field-input w-full mt-2 py-2 text-[#E8E6DE]" />
          </div>
        </div>
        <div>
          <label class="font-mono text-xs uppercase tracking-widest text-[#7C8893]">Email</label>
          <input type="email" required placeholder="name@agency.gov" class="field-input w-full mt-2 py-2 text-[#E8E6DE]" />
        </div>
        <div>
          <label class="font-mono text-xs uppercase tracking-widest text-[#7C8893]">Procurement Need</label>
          <textarea rows="3" placeholder="Commodity logistics, AI systems, or both" class="field-input w-full mt-2 py-2 text-[#E8E6DE] resize-none"></textarea>
        </div>
        <button type="submit" class="btn-gold font-mono text-xs uppercase tracking-widest px-7 py-4">
          Submit Inquiry
        </button>
        <p class="confirm hidden font-mono text-xs text-[#B8924A] tracking-widest">Received. We'll follow up within one business day.</p>
      </form>
    </div>
  </div>

  <div class="max-w-6xl mx-auto mt-28 pt-8 border-t border-[#1C2630] flex flex-col sm:flex-row justify-between gap-4 font-mono text-xs text-[#7C8893] tracking-wide">
    <span>© 2026 Ventoro Ventures LLC. Florida, USA.</span>
    <span>SAM.gov Registered · CAGE Code on Request</span>
  </div>
</section>

<script>
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, { threshold: 0.15 });
  revealEls.forEach(el => io.observe(el));
</script>

</body>
</html>
